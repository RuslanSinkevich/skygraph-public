{
  "name": "@skygraph/vue",
  "version": "0.6.4",
  "description": "SkyGraph Vue 3 adapter вЂ” composables and components built on @skygraph/core",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "Ruslan Sinkevich",
  "homepage": "https://skygraph.ruslansinkevich.ru/vue/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RuslanSinkevich/skygraph-public.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/RuslanSinkevich/skygraph-public/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "composables",
    "ui",
    "form",
    "table",
    "tree",
    "graph",
    "design-system",
    "skygraph"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "api:check": "api-extractor run --verbose",
    "api:update": "api-extractor run --local --verbose",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@skygraph/styles": "workspace:*"
  },
  "peerDependencies": {
    "@skygraph/core": ">=0.1.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.47.0",
    "@skygraph/core": "workspace:*",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.0",
    "@vue/compiler-sfc": "^3.4.0",
    "jsdom": "^25.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
