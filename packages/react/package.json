{
  "name": "@skygraph/react",
  "version": "0.5.1",
  "description": "SkyGraph React adapter — hooks, components and UI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./form": {
      "types": "./dist/form.d.ts",
      "import": "./dist/form.js",
      "require": "./dist/form.cjs"
    },
    "./table": {
      "types": "./dist/table.d.ts",
      "import": "./dist/table.js",
      "require": "./dist/table.cjs"
    },
    "./tree": {
      "types": "./dist/tree.d.ts",
      "import": "./dist/tree.js",
      "require": "./dist/tree.cjs"
    },
    "./datagrid": {
      "types": "./dist/datagrid.d.ts",
      "import": "./dist/datagrid.js",
      "require": "./dist/datagrid.cjs"
    },
    "./virtual": {
      "types": "./dist/virtual.d.ts",
      "import": "./dist/virtual.js",
      "require": "./dist/virtual.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js",
      "require": "./dist/devtools.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "Ruslan Sinkevich",
  "homepage": "https://skygraph.ruslansinkevich.ru/react/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RuslanSinkevich/skygraph-public.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/RuslanSinkevich/skygraph-public/issues"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "form",
    "table",
    "tree",
    "design-system",
    "skygraph"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "api:check": "api-extractor run --verbose",
    "api:update": "api-extractor run --local --verbose",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@skygraph/styles": "workspace:*"
  },
  "peerDependencies": {
    "@skygraph/core": ">=0.1.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.2",
    "@microsoft/api-extractor": "^7.47.0",
    "@skygraph/core": "file:../core",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "axe-core": "^4.10.3",
    "jsdom": "^25.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
