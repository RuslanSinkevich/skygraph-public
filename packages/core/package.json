{
  "name": "@skygraph/core",
  "version": "0.5.0",
  "description": "SkyGraph reactive runtime — state graph engine for UI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./form": {
      "types": "./dist/form.d.ts",
      "import": "./dist/form.js",
      "require": "./dist/form.cjs"
    },
    "./table": {
      "types": "./dist/table.d.ts",
      "import": "./dist/table.js",
      "require": "./dist/table.cjs"
    },
    "./tree": {
      "types": "./dist/tree.d.ts",
      "import": "./dist/tree.js",
      "require": "./dist/tree.cjs"
    },
    "./virtual": {
      "types": "./dist/virtual.d.ts",
      "import": "./dist/virtual.js",
      "require": "./dist/virtual.cjs"
    },
    "./graph": {
      "types": "./dist/graph.d.ts",
      "import": "./dist/graph.js",
      "require": "./dist/graph.cjs"
    },
    "./calendar": {
      "types": "./dist/calendar.d.ts",
      "import": "./dist/calendar.js",
      "require": "./dist/calendar.cjs"
    },
    "./runtime-internal": {
      "types": "./dist/runtime-internal.d.ts",
      "import": "./dist/runtime-internal.js",
      "require": "./dist/runtime-internal.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "Ruslan Sinkevich",
  "homepage": "https://skygraph.ruslansinkevich.ru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RuslanSinkevich/skygraph-public.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/RuslanSinkevich/skygraph-public/issues"
  },
  "keywords": [
    "reactive",
    "state",
    "graph",
    "form",
    "table",
    "tree",
    "engine",
    "skygraph"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "cross-env RUN_BENCH=1 vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "api:check": "api-extractor run --verbose",
    "api:update": "api-extractor run --local --verbose",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.47.0",
    "@vitest/coverage-v8": "^2.1.9",
    "cross-env": "^10.1.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
