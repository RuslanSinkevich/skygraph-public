{
  "name": "skygraph-vue",
  "version": "0.6.4",
  "description": "SkyGraph for Vue 3 — components, composables and styles in a single install",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": {
      "default": "@skygraph/styles"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Ruslan Sinkevich",
  "homepage": "https://skygraph.ruslansinkevich.ru/vue/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RuslanSinkevich/skygraph-public.git",
    "directory": "packages/skygraph-vue"
  },
  "bugs": {
    "url": "https://github.com/RuslanSinkevich/skygraph-public/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "composables",
    "ui",
    "form",
    "table",
    "tree",
    "design-system",
    "skygraph"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@skygraph/core": "workspace:*",
    "@skygraph/vue": "workspace:*",
    "@skygraph/styles": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0"
  }
}
