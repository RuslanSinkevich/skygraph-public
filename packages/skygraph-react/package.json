{
  "name": "skygraph-react",
  "version": "0.6.3",
  "description": "SkyGraph for React — components, hooks and styles in a single install",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": {
      "default": "@skygraph/styles"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Ruslan Sinkevich",
  "homepage": "https://skygraph.ruslansinkevich.ru/react/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RuslanSinkevich/skygraph-public.git",
    "directory": "packages/skygraph-react"
  },
  "bugs": {
    "url": "https://github.com/RuslanSinkevich/skygraph-public/issues"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "form",
    "table",
    "tree",
    "design-system",
    "skygraph"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@skygraph/core": "workspace:*",
    "@skygraph/react": "workspace:*",
    "@skygraph/styles": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
